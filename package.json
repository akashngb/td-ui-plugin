{
  "name": "td-ui-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Internal MCP server that mirrors UI component registries (21st.dev, Aceternity, HeroUI) for GitHub Copilot Agent Mode. Serves shadcn-spec components verbatim from internal_registry.json — never synthesizes.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "td-ui-plugin": "dist/index.js"
  },
  "files": [
    "dist",
    "internal_registry.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "ingest": "tsx src/ingest.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
